{
  "$schema": "https://openclaw.ai/schema/config.json",

  "gateway": {
    "port": 18789,
    "mode": "local",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    },
    "http": {
      "auth": {
        "enabled": false
      },
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },

  "agents": {
    "defaults": {
      "models": {
        "main": {
          "provider": "anthropic",
          "model": "claude-sonnet-4-6"
        }
      }
    }
  },

  "tools": {
    "profile": "full",
    "allow": [
      "exec", "browser", "web_search", "web_fetch",
      "read", "write", "edit", "apply_patch",
      "image", "image_generate",
      "sessions_status", "agents_list",
      "cron"
    ]
  }
}
