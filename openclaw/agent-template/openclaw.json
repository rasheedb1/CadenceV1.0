{
  "$schema": "https://openclaw.ai/schema/config.json",

  "gateway": {
    "port": 18789,
    "mode": "local",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "allowedOrigins": [
        "https://agent-sofi-production.up.railway.app",
        "https://agent-nando-production.up.railway.app",
        "https://chief-dev-bot-production.up.railway.app",
        "https://openclaw-production-1352.up.railway.app",
        "https://twilio-bridge-production-241b.up.railway.app"
      ]
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },

  "agents": {
    "defaults": {
      "models": {
        "main": {}
      }
    }
  },

  "tools": {
    "profile": "full",
    "allow": [
      "exec", "browser", "web_search", "web_fetch",
      "read", "write", "edit", "apply_patch",
      "image", "image_generate",
      "sessions_status", "agents_list",
      "cron"
    ]
  }
}
